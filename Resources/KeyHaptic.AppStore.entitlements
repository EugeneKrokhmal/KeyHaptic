<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Mac App Store / sandboxed build — use with APPSTORE compile flag -->
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<!-- Input Monitoring is requested at runtime via CGRequestListenEventAccess -->
</dict>
</plist>
